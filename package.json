{
  "name": "super-store",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A reactive store primitive backed by a Yjs CRDT — local, collaborative, persistent and undoable behind one in-memory-style API.",
  "license": "MIT",
  "author": "Mert",
  "keywords": ["store", "state", "reactive", "crdt", "yjs", "collaboration", "offline", "undo", "react", "typescript"],
  "repository": { "type": "git", "url": "git+https://github.com/mertdogar/super-store.git" },
  "homepage": "https://mertdogar.github.io/super-store/",
  "bugs": "https://github.com/mertdogar/super-store/issues",
  "packageManager": "pnpm@11.5.1",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "11.5.1",
      "onFail": "download"
    }
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r --if-present test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "oxlint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "docs:dev": "pnpm --filter @super-store/store build && pnpm --filter @super-store/docs dev",
    "docs:build": "pnpm --filter @super-store/store build && pnpm --filter @super-store/docs build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "tsup": "^8.3.5",
    "typescript": "~5.8.3",
    "vitest": "^4.1.2"
  }
}
