{
  "name": "@super-store/react",
  "version": "0.2.0",
  "description": "React hooks for @super-store/store — useStore and useStoreSelector, tear-free over useSyncExternalStore.",
  "keywords": [
    "crdt",
    "hooks",
    "react",
    "reactive",
    "state",
    "store",
    "super-store",
    "typescript"
  ],
  "homepage": "https://mertdogar.github.io/super-store/",
  "bugs": "https://github.com/mertdogar/super-store/issues",
  "license": "MIT",
  "author": "Mert",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mertdogar/super-store.git",
    "directory": "packages/react"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "use-sync-external-store": "^1.4.0"
  },
  "devDependencies": {
    "@super-store/store": "workspace:*",
    "@testing-library/react": "^16.1.0",
    "@types/react": "^19.0.0",
    "@types/use-sync-external-store": "^1.5.0",
    "jsdom": "^25.0.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vitest": "^4.1.2",
    "yjs": "^13.6.27"
  },
  "peerDependencies": {
    "@super-store/store": "workspace:^",
    "react": ">=18"
  },
  "engines": {
    "node": ">=18"
  }
}
